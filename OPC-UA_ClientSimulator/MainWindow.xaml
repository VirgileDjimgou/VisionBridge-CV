<Window x:Class="OPC_UA_ClientSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VisionBridge — Unified Client"
        Height="830" Width="1160"
        Background="#1a1a2e">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- ===== Row 0: Connection Bar ===== -->
        <Border Grid.Row="0" Background="#2d2d3d" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Quelle:" Foreground="#ccc" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="SourceComboBox" Width="145"
                          SelectionChanged="SourceComboBox_SelectionChanged">
                    <ComboBoxItem Content="Lokal (P/Invoke)" IsSelected="True"/>
                    <ComboBoxItem Content="REST API (HTTP)"/>
                    <ComboBoxItem Content="OPC-UA"/>
                </ComboBox>

                <TextBlock x:Name="LblEndpoint" Text="Endpoint:" Foreground="#ccc"
                           VerticalAlignment="Center" Margin="14,0,6,0" Visibility="Collapsed"/>
                <TextBox x:Name="TxtEndpoint" Width="300"
                         Text="opc.tcp://localhost:4840/visionbridge"
                         Background="#3a3a4d" Foreground="White" BorderBrush="#555" Padding="6,4"
                         Visibility="Collapsed"/>

                <Button Content="▶ Start" Margin="12,0,0,0" Padding="14,6"
                        Background="#27ae60" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Click="BtnStart_Click"/>
                <Button Content="■ Stop" Margin="8,0,0,0" Padding="14,6"
                        Background="#c0392b" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Click="BtnStop_Click"/>

                <Ellipse x:Name="StatusDot" Width="14" Height="14" Fill="#c0392b"
                         Margin="16,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Text="Gestoppt" Foreground="#999"
                           VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- ===== Row 1: Main Two-Column Layout ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left: Vision Lab ===== -->
            <Border Grid.Column="0" Background="#2d2d3d" CornerRadius="8"
                    Margin="0,0,8,0" Padding="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Margin="4,8,4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModeComboBox" Grid.Column="0" Width="160"
                                      SelectionChanged="ModeComboBox_SelectionChanged">
                                <ComboBoxItem Content="Farbe (Rot)" IsSelected="True"/>
                                <ComboBoxItem Content="Gesicht"/>
                                <ComboBoxItem Content="Kanten (Canny)"/>
                                <ComboBoxItem Content="Kreise (Hough)"/>
                                <ComboBoxItem Content="🍾 Flascheninspektion"/>
                            </ComboBox>
                            <TextBlock x:Name="ConfidenceText" Grid.Column="1"
                                       Foreground="#f39c12" FontSize="12"
                                       Margin="12,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FpsText" Grid.Column="2"
                                       Foreground="#888" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="PositionText" Foreground="#6BCB77"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Grid x:Name="VideoContainer">
                        <Image x:Name="VideoImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <Canvas x:Name="OverlayCanvas" ClipToBounds="True"/>
                        <TextBlock x:Name="NoSignalText" Text="Kein Signal"
                                   Foreground="#666" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- ===== Right: Control Panel ===== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Detection Values -->
                    <Border Background="#2d2d3d" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="📷 Kamera" Foreground="#6c5ce7" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="TxtCameraRunning" Text="—" Foreground="#ccc"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel x:Name="CameraMethodPanel" Orientation="Horizontal"
                                        Margin="0,0,0,8" Visibility="Collapsed">
                                <Button Content="▶ Kamera" Padding="8,3" Margin="0,0,6,0" FontSize="11"
                                        Background="#27ae60" Foreground="White" BorderThickness="0"
                                        Click="BtnCameraStart_Click"/>
                                <Button Content="■ Kamera" Padding="8,3" FontSize="11"
                                        Background="#c0392b" Foreground="White" BorderThickness="0"
                                        Click="BtnCameraStop_Click"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,5">
                                <TextBlock Text="🔴 Farbe" Foreground="#e74c3c" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtColorInfo" Text="—" Foreground="#ccc" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,5">
                                <TextBlock Text="👤 Gesichter" Foreground="#f39c12" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtFaceInfo" Text="—" Foreground="#ccc" FontSize="12"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="⭕ Kreise" Foreground="#3498db" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtCircleInfo" Text="—" Foreground="#ccc" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Margin="0,5,0,0">
                                <TextBlock Text="🍾 Flasche" Foreground="#2ecc71" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtBottleInfo" Text="—" Foreground="#ccc" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Plant Control -->
                    <Border x:Name="PlantControlPanel" Background="#2d2d3d" CornerRadius="8"
                            Padding="12" Margin="0,0,0,8" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="⚙ Anlagen-Steuerung" Foreground="#6c5ce7"
                                       FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                            <TextBlock Text="Förderband (m/s)" Foreground="#ccc" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Slider x:Name="SliderSpeed" Width="150" Minimum="0" Maximum="5"
                                        Value="1.2" TickFrequency="0.1"
                                        ValueChanged="SliderSpeed_ValueChanged"/>
                                <TextBlock x:Name="TxtSpeedValue" Text="1.2" Foreground="#eee"
                                           FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <CheckBox x:Name="ChkInspection" Content="Inspektion aktiv"
                                      Foreground="#ccc" IsChecked="True"
                                      Click="ChkInspection_Click" Margin="0,0,0,4"/>
                            <CheckBox x:Name="ChkRejectGate" Content="Ausschleusweiche offen"
                                      Foreground="#ccc" IsChecked="False"
                                      Click="ChkRejectGate_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Decision -->
                    <Border Background="#2d2d3d" CornerRadius="8" Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Aktuelle Entscheidung" Foreground="#999"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <Border x:Name="DecisionBorder" CornerRadius="6" Padding="16,8"
                                    Background="#555" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtDecision" Text="— Warte —"
                                           Foreground="White" FontSize="16" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="TxtDecisionCount" Text="" Foreground="#999"
                                       FontSize="11" Margin="0,6,0,0"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== Row 2: Diagnostics ===== -->
        <Border Grid.Row="2" Background="#2d2d3d" CornerRadius="8" Padding="10" Margin="0,10,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtDiagUptime" Text="Uptime: —" Foreground="#ccc" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtDiagBackend" Text="Backend: —" Foreground="#ccc" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtDiagFps" Text="Server FPS: —" Foreground="#ccc" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtDiagInspections" Text="Inspektionen: —" Foreground="#ccc" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ===== Row 3: Sorting Log ===== -->
        <Border Grid.Row="3" Background="#2d2d3d" CornerRadius="8" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Sortierlogik — Entscheidungsprotokoll"
                           Foreground="#6c5ce7" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <ListBox x:Name="LogList" Background="Transparent" BorderThickness="0"
                         Foreground="#ccc" FontFamily="Consolas" FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
