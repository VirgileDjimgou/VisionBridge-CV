      <Window x:Class="VisionClientWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NeuroC Vision"
        Height="660"
        Width="940"
        Background="#1E1E2E">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="230"/>
        </Grid.ColumnDefinitions>

        <!-- Live-Video + Overlay -->
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1"
                Background="Black" CornerRadius="4">
            <Grid x:Name="VideoContainer">
                <Image x:Name="VideoImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <Canvas x:Name="OverlayCanvas"
                        ClipToBounds="True"/>
                <TextBlock x:Name="NoSignalText"
                           Text="Kein Signal"
                           Foreground="#888"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Seitenleiste -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0">

            <TextBlock Text="VisionBridge"
                       FontSize="20" FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,12"/>

            <!-- Datenquelle -->
            <TextBlock Text="Datenquelle" Foreground="#CCC"
                       FontSize="13" Margin="0,0,0,5"/>

            <ComboBox x:Name="SourceComboBox" Width="190" Margin="0,0,0,12">
                <ComboBoxItem Content="Lokal (P/Invoke)" IsSelected="True"/>
                <ComboBoxItem Content="REST API (HTTP)"/>
                <ComboBoxItem Content="OPC-UA"/>
            </ComboBox>

            <!-- Steuerung -->
            <Button Content="▶ Start" Width="190" Height="34"
                    Margin="0,0,0,5" Click="Start_Click"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"/>

            <Button Content="■ Stop" Width="190" Height="34"
                    Margin="0,0,0,12" Click="Stop_Click"
                    Background="#C0392B" Foreground="White" FontWeight="Bold"/>

            <!-- Erkennungsmodus -->
            <TextBlock Text="Erkennungsmodus" Foreground="#CCC"
                       FontSize="13" Margin="0,0,0,5"/>

            <ComboBox x:Name="ModeComboBox" Width="190"
                      SelectionChanged="ModeComboBox_SelectionChanged">
                <ComboBoxItem Content="Farbe (Rot)" IsSelected="True"/>
                <ComboBoxItem Content="Gesicht"/>
                <ComboBoxItem Content="Kanten (Canny)"/>
                <ComboBoxItem Content="Kreise (Hough)"/>
            </ComboBox>

            <!-- Status + Detection -->
            <Border Margin="0,14,0,0" Background="#2D2D44"
                    CornerRadius="4" Padding="10">
                <StackPanel>
                    <TextBlock Text="Erkennung" Foreground="#AAA"
                               FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="StatusText"
                               Foreground="#EEE" FontSize="13"
                               TextWrapping="Wrap"
                               Text="Bereit"/>
                    <TextBlock x:Name="PositionText"
                               Foreground="#6BCB77" FontSize="13"
                               Margin="0,5,0,0"/>
                    <TextBlock x:Name="ConfidenceText"
                               Foreground="#f39c12" FontSize="12"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="FpsText"
                               Foreground="#888" FontSize="11"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Runtime-Diagnose -->
            <Border Margin="0,10,0,0" Background="#2D2D44"
                    CornerRadius="4" Padding="10">
                <StackPanel>
                    <TextBlock Text="📊 Runtime" Foreground="#AAA"
                               FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DiagUptimeText"
                               Foreground="#ccc" FontSize="11" Text="Uptime: —"/>
                    <TextBlock x:Name="DiagBackendText"
                               Foreground="#ccc" FontSize="11" Text="Backend: —"/>
                    <TextBlock x:Name="DiagServerFpsText"
                               Foreground="#ccc" FontSize="11" Text="Server FPS: —"/>
                    <TextBlock x:Name="DiagInspectionsText"
                               Foreground="#ccc" FontSize="11" Text="Inspektionen: —"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>